{
  "functions": {
    "api/proxy.js":      { "maxDuration": 30 },
    "api/sitemap.js":    { "maxDuration": 30 },
    "api/share.js":      { "maxDuration": 15 },
    "api/feed.js":       { "maxDuration": 15 },
    "api/anime-page.js": { "maxDuration": 15 }
  },
  "rewrites": [
    { "source": "/sitemap.xml",       "destination": "/api/sitemap" },
    { "source": "/sitemap-anime.xml", "destination": "/api/sitemap?type=anime" },
    { "source": "/sitemap-index.xml", "destination": "/api/sitemap?type=index" },
    { "source": "/share",             "destination": "/api/share" },
    { "source": "/feed",              "destination": "/api/feed" },
    { "source": "/anime/:id/:slug",   "destination": "/api/anime-page?id=:id&slug=:slug" },
    { "source": "/anime/:id",         "destination": "/api/anime-page?id=:id" },
    { "source": "/(.*)",              "destination": "/index.html" }
  ]
}
